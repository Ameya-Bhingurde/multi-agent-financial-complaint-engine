# ─── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=cfpb
POSTGRES_PASSWORD=cfpb_secret
POSTGRES_DB=complaints_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── LLM Provider ────────────────────────────────────────────
# Set LLM_PROVIDER to choose the active provider:
#   "groq"    → Llama 3 via Groq API (free tier, fast)
LLM_PROVIDER=groq

# Groq / Llama 3 (used when LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_your-groq-key-here
GROQ_MODEL=llama-3.3-70b-versatile
# Other available Groq models:
#   llama3-8b-8192        (faster, lighter)
#   llama-3.1-70b-versatile
#   mixtral-8x7b-32768

# ─── Embeddings ──────────────────────────────────────────────
# BAAI/bge-small-en-v1.5 via sentence-transformers (local, free)

# ─── Qdrant ──────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=cfpb_pages

# ─── PageIndex Service ────────────────────────────────────────
PAGEINDEX_URL=http://localhost:8001

# ─── n8n ─────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=admin123

# ─── CFPB Ingestion ──────────────────────────────────────────
# Optional: path to local CFPB CSV file (skips API call)
CFPB_CSV_PATH=
# Max complaints to ingest per run (0 = unlimited)
INGEST_LIMIT=500

# ─── Aggregation Engine ──────────────────────────────────────
DEBATE_THRESHOLD=2.0
COLD_START_PENALTY=0.15
MIN_SIMILAR_CASES=5

# Agent weights (must sum to 1.0)
WEIGHT_COMPLIANCE=0.30
WEIGHT_FAIRNESS=0.20
WEIGHT_FINANCIAL=0.20
WEIGHT_FRAUD=0.20
WEIGHT_REPUTATION=0.10
